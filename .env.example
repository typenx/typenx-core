# Typenx Core environment
#
# Copy this file to `.env` for local development. The real `.env` file is gitignored.

# Server
TYPENX_BIND_ADDR=127.0.0.1:8080
TYPENX_PUBLIC_BASE_URL=http://127.0.0.1:8080
TYPENX_WEB_REDIRECT_URL=http://127.0.0.1:3000/auth/callback

# Use a long random value in real deployments.
TYPENX_SESSION_SECRET=change-this-long-random-secret

# Database
# SQLite local default:
TYPENX_DATABASE_URL=sqlite://typenx.sqlite?mode=rwc
# Postgres example:
# TYPENX_DATABASE_URL=postgres://typenx:typenx@127.0.0.1:5432/typenx
# MySQL example:
# TYPENX_DATABASE_URL=mysql://typenx:typenx@127.0.0.1:3306/typenx

# Comma-separated remote addons that are always available and cannot be deleted.
TYPENX_BUILTIN_ADDONS=http://127.0.0.1:8787,http://127.0.0.1:8788

# AniList OAuth
# Callback URL to register with AniList:
# http://127.0.0.1:8080/auth/anilist/callback
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# MyAnimeList OAuth
# Callback URL to register with MAL:
# http://127.0.0.1:8080/auth/mal/callback
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
